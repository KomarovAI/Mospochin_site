{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mospochin.ru/schemas/lead-v3.schema.json",
  "title": "MosPochin lead v3",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "tracking_version", "phone", "consent", "page", "page_path", "form_id", "form_variant", "session_id", "tab_id", "idempotency_key", "trace_id", "submit_attempt_event_id"],
  "properties": {
    "schema_version": {"const": "mospochin.lead.v3"},
    "tracking_version": {"const": "2026-07-15"},
    "phone": {"type": "string", "minLength": 10, "maxLength": 64},
    "consent": {"const": true},
    "page": {"type": "string", "pattern": "^[a-z0-9-]+\\.html$"},
    "page_path": {"type": "string", "pattern": "^/"},
    "form_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "form_variant": {"type": "string", "minLength": 1, "maxLength": 256},
    "session_id": {"type": "string", "minLength": 8, "maxLength": 128},
    "tab_id": {"type": "string", "minLength": 8, "maxLength": 128},
    "idempotency_key": {"type": "string", "minLength": 8, "maxLength": 160},
    "trace_id": {"type": "string", "minLength": 8, "maxLength": 160},
    "submit_attempt_event_id": {"type": "string", "minLength": 8, "maxLength": 160},
    "metrika_client_id": {"type": ["string", "null"], "maxLength": 128},
    "landing_path": {"type": ["string", "null"], "maxLength": 1024},
    "first_touch": {"type": ["object", "null"]},
    "last_touch": {"type": ["object", "null"]},
    "first_touch_yclid": {"type": ["string", "null"], "maxLength": 256},
    "last_touch_yclid": {"type": ["string", "null"], "maxLength": 256},
    "yclid_for_offline": {"type": ["string", "null"], "maxLength": 256},
    "yclid_source": {"enum": ["first_touch", "last_touch", null]},
    "gclid": {"type": ["string", "null"], "maxLength": 256}
  }
}

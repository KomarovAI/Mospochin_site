{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mospochin.ru/schemas/ai-project-index.schema.json",
  "title": "MosPochin AI project index",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "project", "summary", "sourceOfTruth", "pages"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "generatedAt": { "type": "string" },
    "note": { "type": "string" },
    "project": { "type": "object" },
    "summary": { "type": "object" },
    "sourceOfTruth": { "type": "object" },
    "pages": { "type": "object" }
  },
  "additionalProperties": false,
  "x-runtimeChecks": [
    "AI index must match deterministic output of tools/generate-ai-index.mjs",
    "Index pages must match page-metadata pages"
  ]
}

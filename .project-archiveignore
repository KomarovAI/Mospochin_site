# MosPochin full-project archive hygiene.
# The public deploy pack is produced separately by `npm run deploy:pack`,
# so deploy/runtime copies and nested ZIPs must not be nested into source handoff archives.

.git/
node_modules/
.venv/
.venv-visual/
venv/
__pycache__/
.pytest_cache/
.cache/

# Build/deploy artifacts: regenerated on demand and shipped separately.
.deploy/dist/
.artifacts/
.archives/
reports/visual-ai-review/
playwright-report/
test-results/

# Never nest archives/log dumps inside the project archive.
*.zip
*.tar
*.tar.gz
*.tgz
*.log

[Unit]
Description=Mospochin Telegram API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/mospochin-current
EnvironmentFile=/etc/mospochin/telegram.env
ExecStart=/usr/bin/node /var/www/mospochin-current/server/telegram-api.mjs
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target

name: Validate Site

on:
  push:
    branches: [main]
  pull_request:
  workflow_dispatch:

concurrency:
  group: validate-site-${{ github.ref }}
  cancel-in-progress: true

env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  validate:
    runs-on: ubuntu-latest
    timeout-minutes: 12
    permissions:
      contents: read
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 24
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Build/check generated HTML parity
        run: npm run build:site -- --check

      - name: Guard generated HTML ownership
        env:
          GITHUB_BASE_SHA: ${{ github.event_name == 'pull_request' && github.event.pull_request.base.sha || github.event.before }}
          GITHUB_SHA: ${{ github.sha }}
        run: npm run check:generated-diff

      - name: Validate site
        run: npm run validate:site

      - name: Check core runtime profile
        run: npm run check:core

      - name: Doctor changed pages
        run: |
          set -euo pipefail
          if [ "${{ github.event_name }}" = "pull_request" ]; then
            export GITHUB_BASE_SHA="${{ github.event.pull_request.base.sha }}"
          else
            export GITHUB_BASE_SHA="${{ github.event.before }}"
          fi
          export GITHUB_SHA="${{ github.sha }}"
          npm run doctor:changed-pages

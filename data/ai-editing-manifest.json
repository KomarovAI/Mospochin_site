{
  "schemaVersion": 1,
  "purpose": "Machine-readable map for AI-assisted editing of MosPochin site.",
  "startHere": [
    "docs/AI_START_HERE.md",
    "docs/DOC_INDEX.md",
    "AGENTS.md",
    "data/project-map.generated.json",
    "data/file-ownership.json",
    "docs/AI_PROJECT_OPERATING_GUIDE.md",
    "AI-CONTEXT.md"
  ],
  "sourceOfTruth": {
    "pageBuilder": "src/site-builder.json",
    "pageModels": "src/pages/<slug>/page.json",
    "pageSections": "src/pages/<slug>/sections/*.html",
    "sharedComponents": "src/components/shared/*",
    "parametricTemplates": "src/components/parametric/*/*.template.html",
    "parametricProps": "content/components/*/*.json",
    "metadata": "data/page-metadata.json",
    "directLandings": "data/direct-landing-pages.json",
    "faq": "content/faq/*",
    "projectMap": "data/project-map.generated.json",
    "fileOwnership": "data/file-ownership.json"
  },
  "generatedDoNotEditDirectly": [
    "root *.html unless syncing builder intentionally",
    "sitemap.xml",
    ".deploy/include-files.txt",
    "data/ai-project-index.json",
    "data/ai-component-map.json",
    ".ai/digest/*",
    "reports/source-complexity.*",
    "content/faq/page-faq-registry.json",
    "data/project-map.generated.json"
  ],
  "criticalCommands": {
    "afterAnyEdit": [
      "npm run verify:fast"
    ],
    "afterLinksFormsOrCTA": [
      "npm run check:conversion-ui"
    ],
    "afterDirectLandingEdit": [
      "npm run generate:direct-landings",
      "npm run check:conversion-ui"
    ],
    "afterMetadataEdit": [
      "npm run sync:metadata",
      "npm run validate:data",
      "npm run validate:site"
    ],
    "afterAiDocsOrIndexEdit": [
      "npm run generate:ai-index",
      "npm run ai:digest",
      "npm run ai:doctor"
    ],
    "beforeHandoff": [
      "npm run sync:generated",
      "npm run check:handoff"
    ],
    "routeTask": [
      "npm run ai:route -- --task <type> --page <file.html>"
    ],
    "afterNavigationLayerEdit": [
      "npm run sync:generated",
      "npm run check:ai",
      "npm run check:ownership"
    ],
    "packageHandoff": [
      "npm run handoff:pack"
    ],
    "afterDocsPrune": [
      "npm run sync:generated",
      "npm run check:core",
      "npm run check:ai",
      "npm run check:handoff"
    ]
  },

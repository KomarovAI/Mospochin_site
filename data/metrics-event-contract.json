{
  "version": "2026-07-12-conversion-p0-v1",
  "purpose": "MosPochin archive-only metrics contract. This file is the local source of truth for required website events, backend log fields, and clean LLM aggregates.",
  "events": [
    "page_view"
  ],
  "backend_events": [
    "qualified_lead",
    "call_answered",
    "repair_order_created",
    "service_contract_created"
  ],
  "bot_policy": {
    "frontend_hints": ["navigator.webdriver", "bot_user_agent", "headlesschrome"],
    "backend_action": "reject_before_accepted_log",
    "rejected_reason": "bot_user_agent"
  },
  "metrika": {
    "counter_id": "109138661",
    "goal_type": "JavaScript event",
    "goal_id_rule": "Use stable snake_case identifiers without / \\ & # ? = \".",
    "goals": [
      "phone_click",
      "whatsapp_click",
      "telegram_click",
      "email_click",
      "form_open",
      "form_start",
      "form_submit_attempt",
      "form_submit_success",
      "form_submit_error",
      "form_validation_error",
      "form_submit_blocked",
      "cta_view",
      "cta_click"
    ]
  },
  "frontend": {
    "attribution_storage_key": "mospochin_attribution_v1",
    "session_storage_key": "mospochin_session_v1",
    "required_runtime_exports": [
      "window.mospochinGetAttribution",
      "window.mospochinGetSession",
      "window.mospochinTrackGoal",
      "window.MospochinAnalytics"
    ],
    "required_guards": [
      "production_only_host_guard",
      "blocked_localhost_guard",
      "automation_hint_guard",
      "event_isTrusted_guard",
      "client_rate_limit"
    ],
    "event_transport": [
      "navigator.sendBeacon",
      "fetch keepalive fallback"
    ],
    "cta_view_rule": {
      "api": "IntersectionObserver",
      "minimum_visible_ratio": 0.5,
      "minimum_visible_ms": 900,
      "dedupe": "once per CTA per page session"
    },
    "event_semantics": {
      "visibility": ["page_view", "cta_view"],
      "decision": [
        "cta_click",
        "phone_click",
        "whatsapp_click",
        "telegram_click",
        "email_click",
        "form_open",
        "form_start",
        "form_submit_attempt",
        "form_submit_success"
      ],
      "form_outcome": [
        "form_submit_attempt",
        "form_submit_success",
        "form_submit_error",
        "form_validation_error",
        "form_submit_blocked"
      ],
      "business_outcome": [
        "qualified_lead",
        "call_answered",
        "repair_order_created",
        "service_contract_created"
      ]
    },
    "required_markup_scripts": [
      "tools/apply-metrics-page-markup.mjs",
      "tools/check-metrics-markup.mjs"
    ]
  },
  "backend": {
    "endpoint": "/api/track-event",
    "accepted_log": "/var/log/mospochin/site_events.jsonl",
    "rejected_log": "/var/log/mospochin/site_event_rejects.jsonl",
    "lead_log": "/var/log/mospochin/direct_leads.jsonl",
    "outcome_endpoint": "/api/track-outcome",
    "outcome_auth": "Bearer token from MOSPOCHIN_OUTCOME_TOKEN; never browser-side",
    "required_log_fields": [
      "event",
      "ts",
      "page_path",
      "page_slug",
      "page_version",
      "page_intent",
      "equipment",
      "service",
      "commercial_segment",
      "cta_id",
      "cta_group",
      "form_variant",
      "utm_source",
      "utm_medium",
      "utm_campaign",
      "utm_content",
      "utm_term",
      "yclid_hash",
      "referrer_host",
      "session_id_hash",
      "event_id",
      "client_event_ts"
    ],
    "required_quality_values": [
      "human_candidate",
      "suspicious",
      "bot",
      "internal",
      "test"
    ],
    "must_hash_fields": [
      "session_id",
      "yclid",
      "ip",
      "phone",
      "name"
    ],
    "forbidden_plaintext_fields_in_logs": [
      "phone",
      "name",
      "problem",
      "comment",
      "ip",
      "user_agent",
      "raw_href",
      "tel_href",
      "mailto_href",
      "whatsapp_phone",
      "telegram_id"
    ],
    "contact_target_policy": "Do not write raw tel:, mailto:, WhatsApp phone numbers, Telegram IDs, full IP or full user-agent to analytics logs. Store redacted target hints and hashes only."
  },
  "llm_outputs": [
    "llm_event_funnel_YYYY-MM-DD.csv",
    "llm_cta_performance_YYYY-MM-DD.csv",
    "llm_internal_link_funnel_YYYY-MM-DD.csv",
    "llm_form_friction_YYYY-MM-DD.csv",
    "llm_traffic_quality_YYYY-MM-DD.csv",
    "llm_rejected_events_summary_YYYY-MM-DD.csv",
    "llm_offline_conversions_YYYY-MM-DD.csv",
    "llm_query_landing_actions_YYYY-MM-DD.csv",
    "llm_landing_mismatch_YYYY-MM-DD.csv",
    "llm_page_scorecard_YYYY-MM-DD.csv",
    "llm_page_improvement_actions_YYYY-MM-DD.csv",
    "llm_events_manifest_YYYY-MM-DD.json"
  ],
  "decision_policy": {
    "primary_quality": "human_candidate",
    "do_not_treat_as_hard_conversion": [
      "phone_click",
      "whatsapp_click",
      "telegram_click",
      "email_click",
      "form_open",
      "form_start",
      "cta_view",
      "cta_click"
    ],
    "hard_conversion": [
      "form_submit_success",
      "backend_lead_created",
      "qualified_lead",
      "repair_order_created",
      "service_contract_created"
    ],
    "qualified_conversion": [
      "lead_qualified",
      "call_answered",
      "whatsapp_dialog_started",
      "repair_order_created",
      "service_contract_created"
    ]
  },
  "page_context": {
    "context_map": "data/metrics-page-context.json",
    "required_body_attrs": [
      "data-page-slug",
      "data-page-intent",
      "data-equipment",
      "data-service",
      "data-commercial-segment",
      "data-page-version"
    ],
    "optional_body_attrs": [
      "data-brand"
    ],
    "required_cta_attrs": [
      "data-cta-id",
      "data-cta-group",
      "data-block"
    ],
    "purpose": "Make page intent, equipment, brand and CTA identity explicit in event payloads instead of relying only on URL inference."
  }
}

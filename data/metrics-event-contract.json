{
  "version": "2026-07-15-paid-tracking-v3",
  "purpose": "MosPochin paid tracking v3 contract: strict frontend event allowlist, attribution v3, cross-tab identity and backward-compatible backend ingestion.",
  "events": [
    "page_view",
    "cta_view",
    "cta_click",
    "phone_click",
    "whatsapp_click",
    "telegram_click",
    "email_click",
    "form_open",
    "form_start",
    "form_submit_attempt",
    "form_submit_success",
    "form_submit_error",
    "form_validation_error",
    "form_submit_blocked",
    "web_vital"
  ],
  "backend_events": [
    "qualified_lead",
    "call_answered",
    "repair_order_created",
    "service_contract_created"
  ],
  "bot_policy": {
    "frontend_hints": [
      "navigator.webdriver",
      "bot_user_agent",
      "headlesschrome"
    ],
    "backend_action": "reject_before_accepted_log",
    "rejected_reason": "bot_user_agent"
  },
  "metrika": {
    "counter_id": "109138661",
    "goal_type": "JavaScript event",
    "goal_id_rule": "Use stable snake_case identifiers without / \\ & # ? = \".",
    "goals": [
      "phone_click",
      "whatsapp_click",
      "form_open",
      "form_submit_attempt",
      "form_submit_success"
    ]
  },
  "frontend": {
    "attribution_storage_key": "mospochin_attribution_v3",
    "session_storage_key": "mospochin_session_v3",
    "required_runtime_exports": [
      "window.mospochinGetAttribution",
      "window.mospochinGetIdentity",
      "window.mospochinGetLeadContext",
      "window.mospochinTrackSiteEvent",
      "window.mospochinTrackGoal"
    ],
    "required_guards": [
      "automation_hint_guard",
      "event_isTrusted_guard",
      "reserved_event_fields",
      "unknown_event_skip",
      "client_rate_limit",
      "storage_error_guard"
    ],
    "event_transport": [
      "navigator.sendBeacon",
      "fetch keepalive fallback"
    ],
    "cta_view_rule": {
      "api": "IntersectionObserver",
      "minimum_visible_ratio": 0.5,
      "minimum_visible_ms": 500,
      "dedupe": "once per CTA per page session"
    },
    "event_semantics": {
      "visibility": [
        "page_view",
        "cta_view"
      ],
      "decision": [
        "cta_click",
        "phone_click",
        "whatsapp_click",
        "telegram_click",
        "email_click",
        "form_open",
        "form_start",
        "form_submit_attempt",
        "form_submit_success"
      ],
      "error": [
        "form_submit_error",
        "form_validation_error",
        "form_submit_blocked"
      ],
      "performance": [
        "web_vital"
      ],
      "business_outcome": [
        "qualified_lead",
        "call_answered",
        "repair_order_created",
        "service_contract_created"
      ]
    },
    "required_markup_scripts": [
      "tools/apply-metrics-page-markup.mjs",
      "tools/check-metrics-markup.mjs"
    ],
    "visitor_storage_key": "mospochin_visitor_v1",
    "tab_storage_key": "mospochin_tab_v1"
  },
  "backend": {
    "endpoint": "/api/track-event",
    "accepted_log": "/var/log/mospochin/site_events.jsonl",
    "rejected_log": "/var/log/mospochin/site_event_rejects.jsonl",
    "lead_log": "/var/log/mospochin/direct_leads.jsonl",
    "outcome_endpoint": "/api/track-outcome",
    "outcome_auth": "Bearer token from MOSPOCHIN_OUTCOME_TOKEN; never browser-side",
    "required_log_fields": [
      "event",
      "ts",
      "page_path",
      "page_slug",
      "page_version",
      "page_intent",
      "equipment",
      "service",
      "commercial_segment",
      "cta_id",
      "cta_group",
      "form_variant",
      "utm_source",
      "utm_medium",
      "utm_campaign",
      "utm_content",
      "utm_term",
      "yclid_hash",
      "referrer_host",
      "session_id_hash",
      "event_id",
      "client_event_ts",
      "symptom_id",
      "equipment_family",
      "probable_node",
      "error_code",
      "cta_position",
      "vital_name",
      "vital_value",
      "vital_rating",
      "navigation_type",
      "effective_connection_type"
    ],
    "required_quality_values": [
      "human_candidate",
      "suspicious",
      "bot",
      "internal",
      "test"
    ],
    "must_hash_fields": [
      "session_id when nonempty",
      "yclid when nonempty",
      "gclid when nonempty",
      "ip",
      "phone",
      "name"
    ],
    "forbidden_plaintext_fields_in_logs": [
      "phone",
      "name",
      "problem",
      "comment",
      "ip",
      "user_agent",
      "raw_href",
      "tel_href",
      "mailto_href",
      "whatsapp_phone",
      "telegram_id"
    ],
    "contact_target_policy": "Do not write raw tel:, mailto:, WhatsApp phone numbers, Telegram IDs, full IP or full user-agent to analytics logs. Store redacted target hints and hashes only.",
    "empty_identifier_policy": "null or omitted; never hash an empty string"
  },
  "llm_outputs": [
    "llm_event_funnel_YYYY-MM-DD.csv",
    "llm_cta_performance_YYYY-MM-DD.csv",
    "llm_internal_link_funnel_YYYY-MM-DD.csv",
    "llm_form_friction_YYYY-MM-DD.csv",
    "llm_traffic_quality_YYYY-MM-DD.csv",
    "llm_rejected_events_summary_YYYY-MM-DD.csv",
    "llm_offline_conversions_YYYY-MM-DD.csv",
    "llm_query_landing_actions_YYYY-MM-DD.csv",
    "llm_landing_mismatch_YYYY-MM-DD.csv",
    "llm_page_scorecard_YYYY-MM-DD.csv",
    "llm_page_improvement_actions_YYYY-MM-DD.csv",
    "llm_events_manifest_YYYY-MM-DD.json"
  ],
  "decision_policy": {
    "primary_quality": "human_candidate",
    "do_not_treat_as_hard_conversion": [
      "phone_click",
      "whatsapp_click",
      "telegram_click",
      "email_click",
      "form_open",
      "form_start",
      "cta_view",
      "cta_click"
    ],
    "hard_conversion": [
      "form_submit_success",
      "backend_lead_created",
      "qualified_lead",
      "repair_order_created",
      "service_contract_created"
    ],
    "qualified_conversion": [
      "lead_qualified",
      "call_answered",
      "whatsapp_dialog_started",
      "repair_order_created",
      "service_contract_created"
    ]
  },
  "page_context": {
    "context_map": "data/metrics-page-context.json",
    "required_body_attrs": [
      "data-page-slug",
      "data-page-intent",
      "data-equipment",
      "data-service",
      "data-commercial-segment",
      "data-page-version"
    ],
    "optional_body_attrs": [
      "data-brand"
    ],
    "required_cta_attrs": [
      "data-cta-id",
      "data-cta-group",
      "data-block"
    ],
    "purpose": "Make page intent, equipment, brand and CTA identity explicit in event payloads instead of relying only on URL inference."
  },
  "web_vitals": {
    "event": "web_vital",
    "metrics": [
      "LCP",
      "INP",
      "CLS"
    ],
    "percentile": "p75",
    "segments": [
      "page_slug",
      "device",
      "navigation_type"
    ],
    "good_thresholds": {
      "LCP_ms": 2500,
      "INP_ms": 200,
      "CLS": 0.1
    }
  },
  "backend_legacy_events": [
    "symptom_selfcheck_started",
    "symptom_selfcheck_completed",
    "symptom_decision_branch_selected",
    "symptom_cause_matrix_viewed",
    "error_code_entered",
    "equipment_model_entered",
    "diagnostic_media_added",
    "cta_after_selfcheck",
    "cta_after_cause_matrix",
    "symptom_service_lead"
  ]
}

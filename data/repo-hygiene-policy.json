      "flags": "iu"
    },
    {
      "source": "final[-_. ]*final",
      "flags": "iu"
    },
    {
      "source": "untitled",
      "flags": "iu"
    },
    {
      "source": "\\(\\d+\\)",
      "flags": "iu"
    },
    {
      "source": "~$",
      "flags": "u"
    }

  "pageUsage": {
    "kuttery-dlya-restoranov": {
      "images": [
        "kutter-industrial-overview",
        "kutter-corroded-drive-coupling",
        "kutter-corroded-drive-assembly",
        "kutter-blade-assembly-bowl"
      ],
      "eyebrow": "Оборудование крупным планом",
      "heading": "Основные узлы профессионального куттера",
      "text": "Фотографии показывают рабочую чашу, ножевой блок и приводную часть оборудования. По внешнему виду можно зафиксировать зону осмотра, но окончательная диагностика выполняется только после безопасной разборки и измерений.",
      "layout": "gallery"
    },
    "remont-kutterov": {
      "images": [
        "kutter-industrial-overview",
        "kutter-corroded-drive-assembly"
      ],
      "eyebrow": "Визуальная диагностика",
      "heading": "От рабочей чаши до приводного узла",
      "text": "При ремонте оценивают не только результат измельчения, но и состояние ножевого блока, вала, муфты, опор и двигателя. Фотографии помогают заранее обозначить проблемную зону в заявке.",
      "layout": "pair"
    },
    "obsluzhivanie-kutterov": {
      "images": [
        "kutter-corroded-drive-coupling",
        "kutter-corroded-drive-assembly"
      ],
      "eyebrow": "Профилактический осмотр",
      "heading": "Загрязнение и коррозия приводной части",
      "text": "Труднодоступные соединения и приводные элементы требуют регулярного осмотра. Налёт, коррозия и старая смазка могут сопровождаться люфтом, шумом и повышенной нагрузкой на двигатель.",
      "layout": "pair"
    },
    "diagnostika-kuttera": {
      "images": [
        "kutter-corroded-drive-assembly"
      ],
      "eyebrow": "Приводная часть",
      "heading": "Что осматривают внутри корпуса куттера",
      "text": "В приводном отсеке проверяют фланец, муфту, вал, опоры, крепления и двигатель. Внешний осмотр дополняют измерением тока, проверкой люфта и испытанием штатных защит.",
      "layout": "single"
    },
    "kak-rabotaet-professionalnyy-kutter": {
      "images": [
        "kutter-industrial-overview",
        "kutter-blade-assembly-bowl"
      ],
      "eyebrow": "Устройство куттера",
      "heading": "Чаша, ножи, вал и защитная крышка",
      "text": "Рабочий результат зависит от согласованной работы чаши, ножевого блока, привода и защитной системы. На фотографиях видны основные элементы, которые участвуют в цикле измельчения.",
      "layout": "pair"
    },
    "chistka-i-dezinfekciya-kuttera": {
      "images": [
        "kutter-blade-assembly-bowl"
      ],
      "eyebrow": "Безопасная очистка",
      "heading": "Ножевой блок очищают только после обесточивания",
      "text": "Перед мойкой оборудование отключают от питания и исключают случайный запуск. Ножи осматривают без касания режущей кромки, а съёмные детали очищают по инструкции конкретной модели.",
      "layout": "single"
    },
    "motor-kuttera-gudit-no-nozhi-ne-krutatsya": {
      "images": [
        "kutter-corroded-drive-assembly"
      ],
      "eyebrow": "Диагностика привода",
      "heading": "Если двигатель работает, а ножевой вал не вращается",
      "text": "Проверка идёт от безопасного состояния ножевого блока к муфте, валу, опорам и пусковой цепи двигателя. Повторный запуск до локализации причины может увеличить повреждение.",
      "layout": "single"
    },
    "kutter-shumit-i-vibriruet": {
      "images": [
        "kutter-corroded-drive-coupling"
      ],
      "eyebrow": "Шум и вибрация",
      "heading": "Муфта и соединения приводного узла",
      "text": "Загрязнение, коррозия, ослабление креплений и износ соединения могут сопровождаться вибрацией. Точную причину определяют после проверки люфта, соосности и состояния опор.",
      "layout": "single"
    },
    "kutter-teryaet-oboroty": {
      "images": [
        "kutter-corroded-drive-assembly"
      ],
      "eyebrow": "Потеря оборотов",
      "heading": "Привод проверяют под контролируемой нагрузкой",
      "text": "Падение скорости может быть связано с двигателем, приводом, опорами или заклиниванием механики. Диагностика включает измерения и проверку узлов без обхода защитной системы.",
      "layout": "single"
    },
    "kutter-ostanavlivaetsya-pod-nagruzkoy": {
      "images": [
        "kutter-corroded-drive-assembly"
      ],
      "eyebrow": "Остановка под нагрузкой",
      "heading": "Механическое сопротивление и состояние привода",
      "text": "Под нагрузкой проявляются проблемы муфты, вала, опор, двигателя и пусковой аппаратуры. До проверки не следует увеличивать загрузку или многократно перезапускать машину.",
      "layout": "single"
    },
    "kutter-ploho-izmelchaet": {
      "images": [
        "kutter-blade-assembly-bowl"
      ],
      "eyebrow": "Качество измельчения",
      "heading": "Состояние ножей и рабочей чаши",
      "text": "Неровный результат может быть связан с режущей кромкой, креплением ножей, загрузкой, скоростью и длительностью цикла. Осмотр выполняют только на полностью обесточенном оборудовании.",
      "layout": "single"
    },
    "tupye-ili-povrezhdennye-nozhi-kuttera": {
      "images": [
        "kutter-blade-assembly-bowl"
      ],
      "eyebrow": "Ножевой узел",
      "heading": "Повреждённые ножи нельзя проверять пробным запуском",
      "text": "Сколы, деформация и нарушение крепления требуют остановки оборудования. Специалист проверяет режущие элементы, шайбы, гайку, баланс и состояние приводного вала.",
      "layout": "single"
    },
    "nozh-kuttera-zaklinilo": {
      "images": [
        "kutter-blade-assembly-bowl"
      ],
      "eyebrow": "Заклинивание ножей",
      "heading": "Ножевой блок не освобождают при подключённом питании",
      "text": "Причиной могут быть посторонний предмет, деформация, неправильная сборка или проблема привода. До разборки оборудование полностью обесточивают и защищают от случайного пуска.",
      "layout": "single"
    },
    "kutter-ne-emulgiruet": {
      "images": [
        "kutter-blade-assembly-bowl"
      ],
      "eyebrow": "Тонкое измельчение",
      "heading": "Эмульгирование зависит от ножей, скорости и загрузки",
      "text": "Перед заменой узлов проверяют состояние режущих кромок, правильность сборки, рабочую скорость, объём партии и длительность цикла.",
      "layout": "single"
    },
    "kutter-mazhet-produkt-vmesto-izmelcheniya": {
      "images": [
        "kutter-blade-assembly-bowl"
      ],
      "eyebrow": "Чистота реза",
      "heading": "Когда продукт мнётся вместо измельчения",
      "text": "Размазывание часто сопровождает затупление ножей, неправильную загрузку или избыточное время обработки. Проверку начинают с безопасного осмотра ножевого блока и чаши.",
      "layout": "single"
    }
  }
}

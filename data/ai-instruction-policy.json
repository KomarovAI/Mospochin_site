        "## Do not add"
      ]
    }
  },
  "forbiddenPatterns": [
    {
      "name": "dated status",
      "source": "\\b20\\d{2}[-/.]\\d{2}[-/.]\\d{2}\\b",
      "flags": "u"
    },
    {
      "name": "release checksum",
      "source": "sha-?256|checksum",
      "flags": "iu"
    },
    {
      "name": "task result heading",
      "source": "^#{1,6}\\s+(status|results?|result|what changed|summary|итог|статус|результат|что изменено)\\b",
      "flags": "imu"
    },
    {
      "name": "terminal transcript",
      "source": "^[\\w.-]+@[\\w.-]+:.*[$#]\\s",
      "flags": "mu"
    },
    {
      "name": "sandbox or file citation",
      "source": "sandbox:|filecite|turn\\d+(file|search|view)",
      "flags": "iu"
    },
    {
      "name": "external URL",
      "source": "https?://",
      "flags": "iu"
    },
    {
      "name": "markdown table",
      "source": "^\\s*\\|.*\\|\\s*$",
      "flags": "mu"
    },
    {
      "name": "task completion prose",
      "source": "\\b(готово|завершено|completed|done)\\b.{0,40}\\b(release|релиз|страниц|pages|проверок|checks)\\b",
      "flags": "iu"
    }
  ],
  "maxCodeFenceLines": 14,
  "unknownInstructionFiles": "error"
}

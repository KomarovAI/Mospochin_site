{
  "schemaVersion": 1,
  "purpose": "Keep AI instruction files short, stable and free of task output or unrelated content.",
  "marker": "<!-- ai-instruction-file: true -->",
  "approvedFiles": {
    "AGENTS.md": {
      "maxLines": 100,
      "maxBytes": 6000,
      "headings": [
        "# Repository Instructions",
        "## Start",
        "## Source of truth",
        "## Editing rules",
        "## Verification",
        "## Instruction hygiene",
        "## Risky zones",
        "## Handoff"
      ]
    },
    "src/pages/AGENTS.md": {
      "maxLines": 55,
      "maxBytes": 3500,
      "headings": [
        "# Page Authoring Instructions",
        "## Scope",
        "## Edit",
        "## Build",
        "## Verify",
        "## Do not add"
      ]
    },
    "data/AGENTS.md": {
      "maxLines": 55,
      "maxBytes": 3500,
      "headings": [
        "# Data Instructions",
        "## Scope",
        "## Edit",
        "## Generate",
        "## Verify",
        "## Do not add"
      ]
    },
    "server/AGENTS.md": {
      "maxLines": 55,
      "maxBytes": 3500,
      "headings": [
        "# Server Instructions",
        "## Scope",
        "## Edit",
        "## Verify",
        "## Do not add"
      ]
    },
    "docs/AGENTS.md": {
      "maxLines": 40,
      "maxBytes": 2600,

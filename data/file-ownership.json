  "rules": [
    "Start with npm run ai:brief and open only the returned context.",
    "Prefer manual/source files over root HTML.",
    "Use npm run ai:verify -- --changed after each iteration.",
    "Use npm run ai:release before packaging or production handoff.",
    "Instruction files contain stable rules only and are protected by check:instruction-hygiene.",
    "Temporary output belongs in .artifacts; durable handoff evidence belongs in reports/handoff.",
    "GitHub workflows are an external canonical deployment surface and may be absent from lightweight rollout archives."
  ],
  "optionalDangerZones": [
    ".github/workflows/**"
  ]

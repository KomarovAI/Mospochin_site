  "html": "<section class=\"bg-white py-16\"><div class=\"mx-auto grid max-w-7xl gap-8 px-4 lg:grid-cols-2\"><div class=\"rounded-3xl border bg-slate-50 p-7\"><h2 class=\"text-3xl font-display font-extrabold text-brand-blue\">Что сделать безопасно</h2><ul class=\"mt-6 space-y-3 text-slate-600\"><li class=\"flex gap-3\"><i class=\"ri-checkbox-circle-line mt-1 text-brand-orange\"></i><span>обесточить прибор</span></li><li class=\"flex gap-3\"><i class=\"ri-checkbox-circle-line mt-1 text-brand-orange\"></i><span>не вскрывать плату под напряжением</span></li><li class=\"flex gap-3\"><i class=\"ri-checkbox-circle-line mt-1 text-brand-orange\"></i><span>записать код ошибки</span></li><li class=\"flex gap-3\"><i class=\"ri-checkbox-circle-line mt-1 text-brand-orange\"></i><span>сфотографировать шильдик и панель</span></li></ul></div><div class=\"rounded-3xl bg-brand-blue p-7 text-white\"><h2 class=\"text-3xl font-display font-extrabold\">Что проверяет мастер</h2><ul class=\"mt-6 space-y-3 text-white/80\"><li class=\"flex gap-3\"><i class=\"ri-checkbox-circle-line mt-1 text-brand-orange\"></i><span>питание и сетевой фильтр</span></li><li class=\"flex gap-3\"><i class=\"ri-checkbox-circle-line mt-1 text-brand-orange\"></i><span>реле и силовые дорожки</span></li><li class=\"flex gap-3\"><i class=\"ri-checkbox-circle-line mt-1 text-brand-orange\"></i><span>шлейфы и разъёмы</span></li><li class=\"flex gap-3\"><i class=\"ri-checkbox-circle-line mt-1 text-brand-orange\"></i><span>датчики температуры и защиты</span></li></ul></div></div></section>"
